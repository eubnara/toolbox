[Unit]
Description=Keep-alive comments for long-running GitHub PRs
Documentation=https://github.com/eubnara/toolbox/tree/main/pr-keepalive
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=%h/bin/pr-keepalive --quiet
# Don't restart on transient API failures — the timer will retry tomorrow.
Restart=no
